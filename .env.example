# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# Neon serverless Postgres connection string (free tier is fine).
# Create a project at https://neon.tech, then copy the pooled connection string.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Auth.js session secret. Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Base URL of the app (used by Auth.js). Local default shown.
AUTH_URL=http://localhost:3000

# 32-byte base64 key used to encrypt opt-in, at-rest AI API keys (AES-256-GCM).
# Generate with: openssl rand -base64 32
# Only needed if users opt into saving their AI key on the server.
KEY_ENCRYPTION_SECRET=
